# Database
# Local dev (SQLite — zero setup):
DATABASE_URL=sqlite+aiosqlite:///./nba_analises.db
# Docker PostgreSQL (docker-compose up -d):
# DATABASE_URL=postgresql+asyncpg://nba_user:nba_pass@localhost:5432/nba_analises
# Render production (set via dashboard):
# DATABASE_URL=postgresql+asyncpg://...

# Auth
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
